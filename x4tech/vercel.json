{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "installCommand": "npm install",
  "rewrites": [
    {
      "source": "/api/supabase/(.*)",
      "destination": "/api/supabase?path=$1"
    },
    {
      "source": "/(.*)",
      "destination": "/"
    }
  ]
}
